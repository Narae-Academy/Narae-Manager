<Window x:Class="NaraeManager.MainWindow"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 Title="Narae Manager" Height="820" Width="1380" WindowStartupLocation="CenterScreen">
 <DockPanel Margin="12">
  <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
   <TextBlock Text="Narae Manager" FontSize="28" FontWeight="Bold"/>
   <TextBlock Text="연도·훈련과정·회차별 코드 관리 / 시간표·훈련일지 자동생성" Foreground="#555"/>
  </StackPanel>
  <TabControl>
   <TabItem Header="① 과정 관리"><Grid Margin="8"><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="420"/></Grid.ColumnDefinitions>
    <DataGrid x:Name="CourseGrid" AutoGenerateColumns="False" IsReadOnly="True" SelectionChanged="CourseGrid_SelectionChanged">
     <DataGrid.Columns><DataGridTextColumn Header="연도" Binding="{Binding Year}" Width="65"/><DataGridTextColumn Header="과정명" Binding="{Binding Name}" Width="*"/><DataGridTextColumn Header="회차" Binding="{Binding Round}" Width="60"/><DataGridTextColumn Header="시작일" Binding="{Binding StartDate,StringFormat=yyyy-MM-dd}" Width="100"/><DataGridTextColumn Header="종료일" Binding="{Binding EndDate,StringFormat=yyyy-MM-dd}" Width="100"/><DataGridTextColumn Header="시간" Binding="{Binding StartTime}" Width="70"/><DataGridTextColumn Header="~" Binding="{Binding EndTime}" Width="70"/></DataGrid.Columns>
    </DataGrid>
    <ScrollViewer Grid.Column="1"><StackPanel Margin="12">
     <TextBlock Text="과정 등록·수정" FontSize="18" FontWeight="Bold" Margin="4"/>
     <TextBlock Text="연도"/><TextBox x:Name="YearBox" Text="2026"/>
     <TextBlock Text="기관명"/><TextBox x:Name="InstitutionBox" Text="나래직업훈련아카데미"/>
     <TextBlock Text="훈련과정명"/><TextBox x:Name="CourseNameBox"/>
     <TextBlock Text="과정 ID"/><TextBox x:Name="CourseCodeBox"/>
     <TextBlock Text="회차"/><TextBox x:Name="RoundBox" Text="1"/>
     <TextBlock Text="시작일 (yyyy-MM-dd)"/><TextBox x:Name="StartDateBox"/>
     <TextBlock Text="종료일 (yyyy-MM-dd)"/><TextBox x:Name="EndDateBox"/>
     <TextBlock Text="수업요일 (월=0 ... 금=4)"/><TextBox x:Name="WeekdaysBox" Text="0,1,2,3,4"/>
     <UniformGrid Columns="2"><StackPanel><TextBlock Text="시작시간"/><TextBox x:Name="StartTimeBox" Text="1400"/></StackPanel><StackPanel><TextBlock Text="종료시간"/><TextBox x:Name="EndTimeBox" Text="1800"/></StackPanel></UniformGrid>
     <TextBlock Text="과정유형"/><ComboBox x:Name="CategoryBox" SelectedIndex="0"><ComboBoxItem Content="SNS"/><ComboBoxItem Content="ITQ"/><ComboBoxItem Content="컴활"/><ComboBoxItem Content="CAD"/><ComboBoxItem Content="디자인"/><ComboBoxItem Content="영상"/></ComboBox>
     <WrapPanel><Button Content="신규" Click="NewCourse_Click"/><Button Content="저장" Click="SaveCourse_Click"/><Button Content="삭제" Click="DeleteCourse_Click"/></WrapPanel>
    </StackPanel></ScrollViewer>
   </Grid></TabItem>
   <TabItem Header="② 과정별 코드"><Grid Margin="8"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
    <ComboBox x:Name="CodeCourseBox" DisplayMemberPath="Display" SelectionChanged="CodeCourseBox_SelectionChanged" Margin="4"/>
    <TabControl Grid.Row="1">
     <TabItem Header="강사 코드"><DockPanel Margin="8"><StackPanel DockPanel.Dock="Top" Orientation="Horizontal"><TextBox x:Name="TeacherNameBox" Width="160"/><TextBox x:Name="TeacherCodeBox" Width="360"/><CheckBox x:Name="TeacherDefaultBox" Content="기본" VerticalAlignment="Center"/><Button Content="추가" Click="AddTeacher_Click"/><Button Content="삭제" Click="DeleteTeacher_Click"/></StackPanel><DataGrid x:Name="TeacherGrid" AutoGenerateColumns="True" IsReadOnly="True"/></DockPanel></TabItem>
     <TabItem Header="강의실 코드"><DockPanel Margin="8"><StackPanel DockPanel.Dock="Top" Orientation="Horizontal"><TextBox x:Name="RoomNameBox" Width="160"/><TextBox x:Name="RoomCodeBox" Width="360"/><CheckBox x:Name="RoomDefaultBox" Content="기본" VerticalAlignment="Center"/><Button Content="추가" Click="AddRoom_Click"/><Button Content="삭제" Click="DeleteRoom_Click"/></StackPanel><DataGrid x:Name="RoomGrid" AutoGenerateColumns="True" IsReadOnly="True"/></DockPanel></TabItem>
     <TabItem Header="교과목 코드"><DockPanel Margin="8"><WrapPanel DockPanel.Dock="Top"><TextBox x:Name="SubjectOrderBox" Width="60" Text="1"/><TextBox x:Name="SubjectNameBox" Width="160"/><TextBox x:Name="SubjectCodeBox" Width="260"/><TextBox x:Name="SubjectHoursBox" Width="80" Text="0"/><ComboBox x:Name="SubjectTeacherBox" Width="260" DisplayMemberPath="TeacherCode"/><ComboBox x:Name="SubjectRoomBox" Width="260" DisplayMemberPath="RoomCode"/><Button Content="추가" Click="AddSubject_Click"/><Button Content="삭제" Click="DeleteSubject_Click"/></WrapPanel><DataGrid x:Name="SubjectGrid" AutoGenerateColumns="True" IsReadOnly="True"/></DockPanel></TabItem>
    </TabControl>
   </Grid></TabItem>
   <TabItem Header="③ 시간표 생성"><StackPanel Margin="12"><ComboBox x:Name="ScheduleCourseBox" DisplayMemberPath="Display"/><WrapPanel><Button Content="검사" Click="ValidateSchedule_Click"/><Button Content="고용24 엑셀 생성" Click="ExportSchedule_Click"/></WrapPanel><TextBox x:Name="SchedulePreview" Height="560" FontFamily="Consolas" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" IsReadOnly="True"/></StackPanel></TabItem>
   <TabItem Header="④ 훈련일지"><StackPanel Margin="12"><ComboBox x:Name="DiaryCourseBox" DisplayMemberPath="Display"/><WrapPanel><Button Content="훈련일지 Excel 생성" Click="ExportDiaryExcel_Click"/><Button Content="훈련일지 PDF 생성" Click="ExportDiaryPdf_Click"/></WrapPanel><TextBlock Text="기본 강사의 이름을 사용하며, ITQ는 파워포인트 → 한글 → 엑셀 순서로 작성합니다." Margin="8"/></StackPanel></TabItem>
  </TabControl>
 </DockPanel>
</Window>
