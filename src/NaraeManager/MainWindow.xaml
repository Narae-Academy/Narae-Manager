<Window x:Class="NaraeManager.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Narae Manager" Height="860" Width="1420" WindowStartupLocation="CenterScreen">
 <DockPanel Margin="12">
  <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10"><TextBlock Text="Narae Manager" FontSize="28" FontWeight="Bold"/><TextBlock Text="기관 → 연도 → 과정 → 회차 기반 핵심 관리" Foreground="#555"/></StackPanel>
  <TabControl TabStripPlacement="Left">
   <TabItem Header="기관 관리"><Grid Margin="8"><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="420"/></Grid.ColumnDefinitions><DataGrid x:Name="InstitutionGrid" AutoGenerateColumns="False" IsReadOnly="True" SelectionChanged="InstitutionGrid_SelectionChanged"><DataGrid.Columns><DataGridTextColumn Header="기관명" Binding="{Binding Name}" Width="*"/><DataGridTextColumn Header="사업자등록번호" Binding="{Binding BusinessNumber}" Width="140"/><DataGridTextColumn Header="대표자" Binding="{Binding RepresentativeName}" Width="100"/><DataGridCheckBoxColumn Header="사용" Binding="{Binding IsActive}" Width="60"/></DataGrid.Columns></DataGrid><StackPanel Grid.Column="1" Margin="12"><TextBlock Text="기관 등록·수정" FontSize="18" FontWeight="Bold"/><TextBlock Text="기관명"/><TextBox x:Name="InstNameBox"/><TextBlock Text="사업자등록번호"/><TextBox x:Name="InstBizBox"/><TextBlock Text="주소"/><TextBox x:Name="InstAddressBox"/><TextBlock Text="전화번호"/><TextBox x:Name="InstPhoneBox"/><TextBlock Text="이메일"/><TextBox x:Name="InstEmailBox"/><TextBlock Text="대표자명"/><TextBox x:Name="InstRepBox"/><CheckBox x:Name="InstActiveBox" Content="사용 여부" IsChecked="True" Margin="0,8"/><WrapPanel><Button Content="신규" Click="NewInstitution_Click"/><Button Content="저장" Click="SaveInstitution_Click"/><Button Content="삭제" Click="DeleteInstitution_Click"/></WrapPanel></StackPanel></Grid></TabItem>
   <TabItem Header="연도 관리"><Grid Margin="8"><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="360"/></Grid.ColumnDefinitions><DataGrid x:Name="YearGrid" AutoGenerateColumns="False" IsReadOnly="True" SelectionChanged="YearGrid_SelectionChanged"><DataGrid.Columns><DataGridTextColumn Header="기관" Binding="{Binding InstitutionName}" Width="*"/><DataGridTextColumn Header="운영 연도" Binding="{Binding Year}" Width="120"/></DataGrid.Columns></DataGrid><StackPanel Grid.Column="1" Margin="12"><TextBlock Text="연도 등록" FontSize="18" FontWeight="Bold"/><TextBlock Text="기관"/><ComboBox x:Name="YearInstitutionBox" DisplayMemberPath="Display"/><TextBlock Text="운영 연도"/><TextBox x:Name="YearValueBox"/><WrapPanel><Button Content="등록" Click="SaveYear_Click"/><Button Content="삭제" Click="DeleteYear_Click"/></WrapPanel></StackPanel></Grid></TabItem>
   <TabItem Header="과정 관리"><Grid Margin="8"><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="420"/></Grid.ColumnDefinitions><DataGrid x:Name="TrainingCourseGrid" AutoGenerateColumns="False" IsReadOnly="True" SelectionChanged="TrainingCourseGrid_SelectionChanged"><DataGrid.Columns><DataGridTextColumn Header="연도" Binding="{Binding Year}" Width="70"/><DataGridTextColumn Header="기관" Binding="{Binding InstitutionName}" Width="180"/><DataGridTextColumn Header="과정명" Binding="{Binding Name}" Width="*"/><DataGridTextColumn Header="과정 ID" Binding="{Binding CourseCode}" Width="120"/><DataGridTextColumn Header="유형" Binding="{Binding CourseType}" Width="80"/><DataGridTextColumn Header="총시간" Binding="{Binding TotalTrainingHours}" Width="70"/><DataGridCheckBoxColumn Header="사용" Binding="{Binding IsActive}" Width="60"/></DataGrid.Columns></DataGrid><StackPanel Grid.Column="1" Margin="12"><TextBlock Text="과정 등록·수정" FontSize="18" FontWeight="Bold"/><TextBlock Text="기관/연도"/><ComboBox x:Name="CourseYearBox" DisplayMemberPath="Display"/><TextBlock Text="과정명"/><TextBox x:Name="CourseNameBox"/><TextBlock Text="과정 ID"/><TextBox x:Name="CourseCodeBox"/><TextBlock Text="과정 유형"/><ComboBox x:Name="CourseTypeBox" SelectedIndex="0"><ComboBoxItem Content="SNS"/><ComboBoxItem Content="ITQ"/><ComboBoxItem Content="컴활"/><ComboBoxItem Content="CAD"/><ComboBoxItem Content="디자인"/><ComboBoxItem Content="영상"/></ComboBox><TextBlock Text="총 훈련시간"/><TextBox x:Name="CourseHoursBox" Text="0"/><CheckBox x:Name="CourseActiveBox" Content="사용 여부" IsChecked="True" Margin="0,8"/><WrapPanel><Button Content="신규" Click="NewTrainingCourse_Click"/><Button Content="저장" Click="SaveTrainingCourse_Click"/><Button Content="삭제" Click="DeleteTrainingCourse_Click"/></WrapPanel></StackPanel></Grid></TabItem>
   <TabItem Header="회차 관리"><Grid Margin="8"><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="430"/></Grid.ColumnDefinitions><DataGrid x:Name="RoundGrid" AutoGenerateColumns="False" IsReadOnly="True" SelectionChanged="RoundGrid_SelectionChanged"><DataGrid.Columns><DataGridTextColumn Header="과정" Binding="{Binding CourseName}" Width="*"/><DataGridTextColumn Header="회차" Binding="{Binding RoundNo}" Width="60"/><DataGridTextColumn Header="시작일" Binding="{Binding StartDate,StringFormat=yyyy-MM-dd}" Width="100"/><DataGridTextColumn Header="종료일" Binding="{Binding EndDate,StringFormat=yyyy-MM-dd}" Width="100"/><DataGridTextColumn Header="상태" Binding="{Binding Status}" Width="90"/><DataGridTextColumn Header="정원" Binding="{Binding Capacity}" Width="60"/><DataGridTextColumn Header="총시간" Binding="{Binding TotalTrainingHours}" Width="70"/></DataGrid.Columns></DataGrid><StackPanel Grid.Column="1" Margin="12"><TextBlock Text="회차 등록·수정" FontSize="18" FontWeight="Bold"/><TextBlock Text="과정"/><ComboBox x:Name="RoundCourseBox" DisplayMemberPath="Display"/><TextBlock Text="회차"/><TextBox x:Name="RoundNoBox" Text="1"/><TextBlock Text="시작일 (yyyy-MM-dd)"/><TextBox x:Name="RoundStartDateBox"/><TextBlock Text="종료일 (yyyy-MM-dd)"/><TextBox x:Name="RoundEndDateBox"/><TextBlock Text="수업 요일 (월=0 ... 금=4)"/><TextBox x:Name="RoundWeekdaysBox" Text="0,1,2,3,4"/><UniformGrid Columns="2"><StackPanel><TextBlock Text="시작시간"/><TextBox x:Name="RoundStartTimeBox" Text="1400"/></StackPanel><StackPanel><TextBlock Text="종료시간"/><TextBox x:Name="RoundEndTimeBox" Text="1800"/></StackPanel></UniformGrid><TextBlock Text="정원"/><TextBox x:Name="RoundCapacityBox" Text="20"/><TextBlock Text="상태"/><TextBox x:Name="RoundStatusBox" Text="운영예정"/><TextBlock Text="총 훈련시간"/><TextBox x:Name="RoundHoursBox" Text="0"/><WrapPanel><Button Content="신규" Click="NewRound_Click"/><Button Content="저장" Click="SaveRound_Click"/><Button Content="삭제" Click="DeleteRound_Click"/></WrapPanel></StackPanel></Grid></TabItem>
   <TabItem Header="회차별 코드"><Grid Margin="8"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><ComboBox x:Name="CodeCourseBox" DisplayMemberPath="Display" SelectionChanged="CodeCourseBox_SelectionChanged" Margin="4"/><TabControl Grid.Row="1"><TabItem Header="강사 코드"><DockPanel Margin="8"><StackPanel DockPanel.Dock="Top" Orientation="Horizontal"><TextBox x:Name="TeacherNameBox" Width="160"/><TextBox x:Name="TeacherCodeBox" Width="360"/><CheckBox x:Name="TeacherDefaultBox" Content="기본"/><Button Content="추가" Click="AddTeacher_Click"/><Button Content="삭제" Click="DeleteTeacher_Click"/></StackPanel><DataGrid x:Name="TeacherGrid" AutoGenerateColumns="True" IsReadOnly="True"/></DockPanel></TabItem><TabItem Header="강의실 코드"><DockPanel Margin="8"><StackPanel DockPanel.Dock="Top" Orientation="Horizontal"><TextBox x:Name="RoomNameBox" Width="160"/><TextBox x:Name="RoomCodeBox" Width="360"/><CheckBox x:Name="RoomDefaultBox" Content="기본"/><Button Content="추가" Click="AddRoom_Click"/><Button Content="삭제" Click="DeleteRoom_Click"/></StackPanel><DataGrid x:Name="RoomGrid" AutoGenerateColumns="True" IsReadOnly="True"/></DockPanel></TabItem><TabItem Header="교과목 코드"><DockPanel Margin="8"><WrapPanel DockPanel.Dock="Top"><TextBox x:Name="SubjectOrderBox" Width="60" Text="1"/><TextBox x:Name="SubjectNameBox" Width="160"/><TextBox x:Name="SubjectCodeBox" Width="260"/><TextBox x:Name="SubjectHoursBox" Width="80" Text="1"/><ComboBox x:Name="SubjectTeacherBox" Width="260" DisplayMemberPath="TeacherCode"/><ComboBox x:Name="SubjectRoomBox" Width="260" DisplayMemberPath="RoomCode"/><Button Content="추가" Click="AddSubject_Click"/><Button Content="삭제" Click="DeleteSubject_Click"/></WrapPanel><DataGrid x:Name="SubjectGrid" AutoGenerateColumns="True" IsReadOnly="True"/></DockPanel></TabItem></TabControl></Grid></TabItem>
   <TabItem Header="시간표 생성"><StackPanel Margin="12"><ComboBox x:Name="ScheduleCourseBox" DisplayMemberPath="Display"/><WrapPanel><Button Content="검사" Click="ValidateSchedule_Click"/><Button Content="고용24 엑셀 생성" Click="ExportSchedule_Click"/></WrapPanel><TextBox x:Name="SchedulePreview" Height="560" FontFamily="Consolas" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" IsReadOnly="True"/></StackPanel></TabItem>
   <TabItem Header="훈련일지"><StackPanel Margin="12"><ComboBox x:Name="DiaryCourseBox" DisplayMemberPath="Display"/><WrapPanel><Button Content="훈련일지 Excel 생성" Click="ExportDiaryExcel_Click"/><Button Content="훈련일지 PDF 생성" Click="ExportDiaryPdf_Click"/></WrapPanel><TextBlock Text="기본 강사의 이름을 사용하며, ITQ는 파워포인트 → 한글 → 엑셀 순서로 작성합니다." Margin="8"/></StackPanel></TabItem>
  </TabControl>
 </DockPanel>
</Window>
